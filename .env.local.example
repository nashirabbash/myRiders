# TrackRide Frontend Environment Variables Template
# Reference: CLAUDE.md > 1.3 Environment variables
# Copy this file to .env.local and fill in your values

# API Configuration
# For local development: http://localhost:3000/v1 (make sure backend is running)
# For production: https://api.trackride.app/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/v1

# WebSocket Configuration
# For local development: ws://localhost:3000/v1
# For production: wss://api.trackride.app/v1
EXPO_PUBLIC_WS_URL=ws://localhost:3000/v1

# Google Maps API Key
# Create keys at: https://console.cloud.google.com/
# Enable: Maps SDK for Android, Maps SDK for iOS
# Recommended: create two separate keys, each restricted to one platform
EXPO_PUBLIC_MAPS_API_KEY=your_google_maps_key_here
