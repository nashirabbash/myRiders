# Google Maps API Keys
# Create keys at: https://console.cloud.google.com/
# Enable: Maps SDK for Android, Maps SDK for iOS
#
# Recommended: create two separate keys, each restricted to one platform.

GOOGLE_MAPS_API_KEY_ANDROID=your_android_key_here
GOOGLE_MAPS_API_KEY_IOS=your_ios_key_here

# Backend API base URL
API_BASE_URL=http://localhost:8080
